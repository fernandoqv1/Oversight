{
  "name": "oversight-desktop",
  "version": "1.0.2",
  "description": "Oversight Desktop - Standalone offline project management application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --config.win.signAndEditExecutable=false",
    "build:dir": "electron-builder --win --dir",
    "release": "electron-builder --win --publish always",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": ["oversight", "project-management", "electron"],
  "author": "AsbTrack",
  "license": "ISC",
  "devDependencies": {
    "adm-zip": "^0.5.16",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@fontsource/inter": "^5.0.0",
    "docxtemplater": "^3.68.1",
    "docxtemplater-image-module-free": "^1.1.1",
    "electron-updater": "^6.8.3",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.asbtrack.oversight",
    "productName": "Oversight Desktop",
    "copyright": "Copyright © 2024 AsbTrack",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules/**/*",
      "!dist/**/*",
      "!dist-packaged/**/*",
      "!dist-build/**/*",
      "!dist-release/**/*",
      "!oversight/**/*",
      "!oversight_example/**/*",
      "!example_oversight/**/*",
      "!asbtract_template/**/*",
      "!templates/~$*.docx",
      "!*.log",
      "!.git/**/*",
      "!.cursor/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Oversight Desktop"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "fernandoqv1",
        "repo": "Oversight",
        "releaseType": "release"
      }
    ]
  }
}
